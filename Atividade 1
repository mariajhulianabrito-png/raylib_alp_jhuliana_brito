#include "raylib.h"

int main()
{
    Texture2D feliz;
    Texture2D inimigo;  // Vou ter uma imagem chamada sprite

    InitWindow(800, 450, "basic window");

    feliz = LoadTexture("feliz.png");   
    inimigo = LoadTexture("inimigo.png");// Carregue a imagem sprite.png para usar no jogo

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(feliz, 10, 10, WHITE);
        DrawTexture(inimigo, 20, 20, WHITE);

        EndDrawing();
    }
    
    UnloadTexture(feliz);
    UnloadTexture(inimigo);

    CloseWindow();

    return 0;
}
